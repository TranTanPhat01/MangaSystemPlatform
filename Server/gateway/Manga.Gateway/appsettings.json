{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/identity"
          }
        ]
      },
      "manga-route": {
        "ClusterId": "manga-cluster",
        "Match": {
          "Path": "/manga/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/manga"
          }
        ]
      },
      "editorial-route": {
        "ClusterId": "editorial-cluster",
        "Match": {
          "Path": "/editorial/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/editorial"
          }
        ]
      },
      "file-route": {
        "ClusterId": "file-cluster",
        "Match": {
          "Path": "/files/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/files"
          }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-api": {
            "Address": "http://localhost:5101/"
          }
        }
      },
      "manga-cluster": {
        "Destinations": {
          "manga-api": {
            "Address": "http://localhost:5102/"
          }
        }
      },
      "editorial-cluster": {
        "Destinations": {
          "editorial-api": {
            "Address": "http://localhost:5103/"
          }
        }
      },
      "file-cluster": {
        "Destinations": {
          "file-api": {
            "Address": "http://localhost:5104/"
          }
        }
      }
    }
  }
}
