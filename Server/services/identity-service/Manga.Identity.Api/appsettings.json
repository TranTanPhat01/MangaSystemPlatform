{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "IdentityDb": "Host=localhost;Port=5432;Database=IdentityDB;Username=postgres;Password=12345"
  },
  "Jwt": {
    "Issuer": "MangaSystemPlatform.Identity",
    "Audience": "MangaSystemPlatform.Client",
    "SecretKey": "change-this-development-secret-key-32-plus-chars",
