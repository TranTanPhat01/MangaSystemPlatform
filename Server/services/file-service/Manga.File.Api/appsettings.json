{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "FileDb": "Host=localhost;Port=5432;Database=FileServiceDB;Username=postgres;Password=12345"
  },
  "FileStorage": {
    "Provider": "Local",
    "RootPath": "storage/files",
    "MaxFileSizeInMb": 20,
    "AllowedExtensions": [
      ".png",
      ".jpg",
      ".jpeg",
      ".webp",
      ".pdf",
      ".psd"
    ]
  },
  "Jwt": {
    "Issuer": "MangaSystemPlatform.Identity",
    "Audience": "MangaSystemPlatform.Client",
    "SecretKey": "change-this-development-secret-key-32-plus-chars"
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "ExchangeName": "manga-system-events"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "MinIO": {
    "Endpoint": "localhost:9000",
    "AccessKey": "admin",
    "SecretKey": "password123",
    "BucketName": "manga-assets",
    "UseSSL": false
  }
}
