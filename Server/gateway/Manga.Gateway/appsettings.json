{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        }
      },
      "manga-route": {
        "ClusterId": "manga-cluster",
        "Match": {
          "Path": "/manga/{**catch-all}"
        }
      },
      "files-route": {
        "ClusterId": "files-cluster",
        "Match": {
          "Path": "/files/{**catch-all}"
        }
      },
      "editorial-route": {
        "ClusterId": "editorial-cluster",
        "Match": {
          "Path": "/editorial/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-api": {
            "Address": "http://localhost:5207/"
          }
        }
      },
      "manga-cluster": {
        "Destinations": {
          "manga-api": {
            "Address": "http://localhost:5078/"
          }
        }
      },
      "files-cluster": {
        "Destinations": {
          "file-api": {
            "Address": "http://localhost:5154/"
          }
        }
      },
      "editorial-cluster": {
        "Destinations": {
          "editorial-api": {
            "Address": "http://localhost:5206/"
          }
        }
      }
    }
  }
}
